    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://www.googleapis.com/upload/youtube/v3/videos?uploadType=resumable&part=snippet,status",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$json.youtubeAccessToken}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json; charset=UTF-8"
            },
            {
              "name": "X-Upload-Content-Type",
              "value": "={{$json.mimeType}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={\n  \"snippet\": {\n    \"title\": $json.title,\n    \"description\": $json.description,\n    \"tags\": $json.tags,\n    \"categoryId\": \"22\"\n  },\n  \"status\": {\n    \"privacyStatus\": $json.privacyStatus,\n    \"selfDeclaredMadeForKids\": false\n  }\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "string"
            }
          }
        }
      },
      "id": "HTTP_Init_Resumable",
      "name": "Init Resumable Session",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        20,
        180
      ],
      "retryOnFail": true,
      "maxTries": 4,
      "waitBetweenTries": 4000
    },
    {
      "parameters": {
        "jsCode": "const uploadUrl = $json.headers?.location || $json.headers?.Location || null;\nif (!uploadUrl) {\n  throw new Error('YouTube upload URL missing in init response headers');\n}\nreturn [{ json: { youtubeUploadUrl: uploadUrl } }];"
      },
      "id": "Code_Extract_Upload_Url",
      "name": "Extract Upload URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        180
      ]
    },
    {
      "parameters": {
        "mode": "combine"
      },
      "id": "Merge_Binary_And_Url",
