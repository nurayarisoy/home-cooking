      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{($json.headers?.['x-webhook-secret'] || $json.headers?.['X-Webhook-Secret'] || '') === $env.N8N_SOCIAL_WEBHOOK_SECRET}}",
              "operation": "isTrue"
            }
          ]
        }
      },
      "id": "IF_Secret_Valid",
      "name": "Secret Valid?",
