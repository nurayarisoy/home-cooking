      "position": [
        -880,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst title = String(body.title || '').trim().slice(0, 100) || 'Home Cooking Recipe';\nconst description = String(body.description || '').trim().slice(0, 4900);\nconst mediaUrl = String(body.mediaUrl || '').trim();\nconst tags = Array.isArray(body.tags) ? body.tags.map((v) => String(v).trim()).filter(Boolean) : [];\nconst privacyStatus = String(body.privacyStatus || 'public');\n\nconst mimeType = mediaUrl.match(/\\.(mp4|m4v|mov|webm)(\\?.*)?$/i) ? 'video/mp4' : 'application/octet-stream';\n\nif (!mediaUrl) {\n  throw new Error('mediaUrl is required for YouTube direct upload workflow');\n}\n\nreturn [{\n  json: {\n    title,\n    description,\n    mediaUrl,\n    tags,\n    privacyStatus,\n    mimeType\n  }\n}];"
      },
      "id": "Code_Normalize",
      "name": "Normalize YouTube Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -880,
        20
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://oauth2.googleapis.com/token",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            {
              "name": "client_id",
              "value": "={{$env.YOUTUBE_CLIENT_ID}}"
            },
            {
              "name": "client_secret",
              "value": "={{$env.YOUTUBE_CLIENT_SECRET}}"
            },
            {
              "name": "refresh_token",
              "value": "={{$env.YOUTUBE_REFRESH_TOKEN}}"
            },
            {
              "name": "grant_type",
              "value": "refresh_token"
            }
          ]
        },
        "options": {}
      },
      "id": "HTTP_Refresh_Token",
      "name": "Refresh YouTube Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -640,
        200
      ],
      "retryOnFail": true,
      "maxTries": 4,
      "waitBetweenTries": 4000
    },
    {
      "parameters": {
        "jsCode": "const token = String($json.access_token || '').trim();\nif (!token) {\n  throw new Error('YouTube access token missing after refresh');\n}\nreturn [{ json: { youtubeAccessToken: token } }];"
      },
      "id": "Code_Extract_Token",
      "name": "Extract Access Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -420,
        200
      ]
    },
    {
      "parameters": {
        "mode": "combine"
      },
