        "jsCode": "const uploadUrl = $json.headers?.location || $json.headers?.Location || null;\nreturn [{\n  json: {\n    ...$json,\n    youtubeUploadUrl: uploadUrl,\n    note: uploadUrl\n      ? 'Resumable session created. Upload binary video bytes to youtubeUploadUrl in next step.'\n      : 'No resumable upload URL found in response headers.'\n  }\n}];"
