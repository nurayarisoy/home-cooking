    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst recipe = body.recipe || {};\nconst platforms = Array.isArray(body.platforms) ? body.platforms : [];\n\nconst title = String(recipe.title || '').trim().slice(0, 95);\nconst ingredientsText = String(recipe.ingredientsText || '').trim();\nconst instructionsText = String(recipe.instructionsText || '').trim();\nconst mediaUrl = String(recipe.mediaUrl || '').trim();\nconst mediaType = String(recipe.mediaType || '').trim().toLowerCase() || 'image';\nconst isVideo = mediaType === 'video';\n\nconst baseCaption = [\n  title,\n  '',\n  ingredientsText ? `Ingredients: ${ingredientsText}` : '',\n  instructionsText ? `Instructions: ${instructionsText}` : '',\n  '',\n  '#homecooking #recipe #food #foodie #cooking'\n].filter(Boolean).join('\\n');\n\nconst youtubeDescription = [\n  ingredientsText ? `Ingredients:\\n${ingredientsText}` : '',\n  '',\n  instructionsText ? `Instructions:\\n${instructionsText}` : '',\n  '',\n  '#shorts #recipe #homecooking'\n].filter(Boolean).join('\\n');\n\nreturn [{\n  json: {\n    event: body.event || 'recipe.publish',\n    action: body.action || 'published',\n    occurredAt: body.occurredAt || new Date().toISOString(),\n    platforms,\n    title,\n    mediaUrl,\n    mediaType,\n    isVideo,\n    instagramCaption: baseCaption.slice(0, 2200),\n    youtubeTitle: title.slice(0, 100),\n    youtubeDescription: youtubeDescription.slice(0, 4900),\n    tags: ['homecooking', 'recipe', 'food', 'cooking'],\n    recipeId: recipe.id || null,\n    authorEmail: recipe.authorEmail || null\n  }\n}];"
      },
