# Persistent DB (recommended for Vercel)
MONGODB_URI=
MONGODB_DB=home_cooking

# Auth cookie signing secret
SESSION_SECRET=

# Optional: protects /api/integrations/status in production
STATUS_API_KEY=

# Optional SQLite override for local development
# DATABASE_PATH=/absolute/path/to/database.db

# Optional social auto-publish (n8n)
N8N_SOCIAL_WEBHOOK_URL=
N8N_SOCIAL_WEBHOOK_SECRET=
SITE_URL=

# n8n YouTube direct upload mode
YOUTUBE_DIRECT_ENABLED=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PUBLISH_WEBHOOK_URL=

# n8n Instagram publish
IG_USER_ID=
IG_ACCESS_TOKEN=

# n8n alert channels
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
